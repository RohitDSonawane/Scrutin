# ──────────────────────────────────────────────────────────────────────────────
# Scrutin Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored so secrets stay local.
# ──────────────────────────────────────────────────────────────────────────────

# URL of the Python backend API server (FastAPI).
# In development: start with `python -m app.server` in the backend/ directory.
# Default port is 8000.
VITE_API_URL=http://localhost:8000

# (Optional) Vite dev server port — defaults to 5173
# PORT=5173
