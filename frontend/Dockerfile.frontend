FROM node:20-slim

WORKDIR /workspace

# Install pnpm
RUN npm install -g pnpm

# Copy workspace config
COPY pnpm-workspace.yaml .
COPY pnpm-lock.yaml .
COPY package.json .
COPY tsconfig.base.json .
COPY tsconfig.json .
COPY .npmrc .

# Copy all packages
COPY lib/ lib/
COPY artifacts/ artifacts/

# Install all dependencies
RUN pnpm install --frozen-lockfile

EXPOSE 5173

# Run the scrutin Vite dev server
CMD ["pnpm", "--filter", "@workspace/scrutin", "run", "dev"]
