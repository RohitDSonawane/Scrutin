# ─── PRIMARY LLM PROVIDERS ────────────────────────────────────────────────────
# Google Gemini (Orchestrator, Evidence, Forensics agents)
GOOGLE_API_KEY=AIza...

# Groq (Decomposition, Credibility, Adversarial agents)
GROQ_API_KEY=gsk_...

# ─── WEB SEARCH ───────────────────────────────────────────────────────────────
# Serper.dev (Google search wrapper) — 4 keys available, 2500 queries each
SERPER_API_KEY=your_primary_key
SERPER_API_KEY_2=your_second_key
SERPER_API_KEY_3=your_third_key
SERPER_API_KEY_4=your_fourth_key

# ─── FACT CHECK ───────────────────────────────────────────────────────────────
# Google Fact Check Tools API (free, requires Google Cloud API key)
GOOGLE_FACT_CHECK_API_KEY=AIza...

# ─── MEMORY / VECTOR STORE ────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...

# ─── SOCIAL MEDIA (optional for MVP) ─────────────────────────────────────────
# Reddit (PRAW) — get at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_USER_AGENT=scrutin_hackathon_v1

# ─── TRANSCRIPTION (optional — Groq key above is reused for Whisper) ──────────
# Uncomment if you want OpenAI Whisper as fallback
# OPENAI_API_KEY=sk-...

# ─── MODELS ───────────────────────────────────────────────────────────────────
ORCHESTRATOR_MODEL=google:gemini-3-flash-preview
DECOMPOSITION_MODEL=groq:llama-3.1-8b-instant
EVIDENCE_MODEL=google:gemini-3-flash-preview
CREDIBILITY_MODEL=groq:llama-3.3-70b-versatile
FORENSICS_MODEL=google:gemini-3-flash-preview
ADVERSARIAL_MODEL=groq:llama-3.3-70b-versatile
EMBEDDING_MODEL=gemini-embedding-001

# ─── DATABASE ─────────────────────────────────────────────────────────────────
SCRUTIN_DB_PATH=scrutin.db
